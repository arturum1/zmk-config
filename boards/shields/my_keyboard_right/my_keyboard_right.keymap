#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>

/ {
    behaviors {
        /* Define a custom actuation: Press at 2.0mm (50%), Release at 1.8mm (45%) */
        he_standard: he_standard {
            compatible = "he,behavior-adjustable-actuation";
            #binding-cells = <0>;
            press-threshold-percent = <50>;
            release-threshold-percent = <45>;
        };
    };

    keymap {
        compatible = "zmk,keymap";
        default_layer {
            // Right half keymap - mirrored layout from left half for standard split keyboard
            // The bindings list must contain exactly 44 entries (matches overlay map)
            // Each analog key uses &he_standard &kp <keycode> for Hall Effect actuation
            bindings = <
                /* Row 0 (Mux 0): 16 keys - Mirrored number row (right side) */
                &he_standard &kp BSPC &he_standard &kp GRAVE &he_standard &kp BSLH &he_standard &kp EQUAL
                &he_standard &kp MINUS &he_standard &kp N0 &he_standard &kp N9 &he_standard &kp N8
                &he_standard &kp N7 &he_standard &kp N6 &he_standard &kp N5 &he_standard &kp N4
                &he_standard &kp N3 &he_standard &kp N2 &he_standard &kp N1 &he_standard &kp ESC

                /* Row 1 (Mux 1): 16 keys - Mirrored QWERTY row */
                &he_standard &kp PG_UP &he_standard &kp DEL &he_standard &kp RET &he_standard &kp RBKT
                &he_standard &kp LBKT &he_standard &kp P &he_standard &kp O &he_standard &kp I
                &he_standard &kp U &he_standard &kp Y &he_standard &kp T &he_standard &kp R
                &he_standard &kp E &he_standard &kp W &he_standard &kp Q &he_standard &kp TAB

                /* Row 2 (Mux 2): 12 keys (channels 0-11) - Mirrored home row */
                &he_standard &kp SQT &he_standard &kp SEMI &he_standard &kp L &he_standard &kp K
                &he_standard &kp J &he_standard &kp H &he_standard &kp G &he_standard &kp F
                &he_standard &kp D &he_standard &kp S &he_standard &kp A &he_standard &kp LCTRL
            >;
            // Total: 16 + 16 + 12 = 44 keys (matches overlay map entries)
            // Note: This is a mirrored layout. Adjust keycodes to match your physical right-half plate design.
        };
    };
};
