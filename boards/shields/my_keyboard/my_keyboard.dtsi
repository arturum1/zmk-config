#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/led/led.h>
#include <dt-bindings/adc/adc.h>

#define M_RC(row, col) (row * 16 + col)

/ {
    chosen {
        zmk,matrix_transform = &default_transform;
        zmk,underglow = &led_strip;
    };

    kscan_forwarder: kscan_forwarder {
        compatible = "he,kscan-forwarder";
    };

    he_pass: he_pass {
        compatible = "he,input-processor-adjustable-actuation";
        #input-processor-cells = <1>;
        sensitivity = <250>;
        kscan-forwarder = <&kscan_forwarder>;
        kscan-passthrough;
        kscan-passthrough-position = <2000>;
        keymap-size = <88>; // Total keys
    };

    /* Combined 88-key matrix transform (6 rows x 16 columns) */
    /* Left half: Rows 0-2 | Right half: Rows 3-5 */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <6>;
        map = <
            /* Left Half */
            M_RC(0,0) M_RC(0,1) M_RC(0,2) M_RC(0,3) M_RC(0,4) M_RC(0,5) M_RC(0,6) M_RC(0,7)
            M_RC(0,8) M_RC(0,9) M_RC(0,10) M_RC(0,11) M_RC(0,12) M_RC(0,13) M_RC(0,14) M_RC(0,15)
            M_RC(1,0) M_RC(1,1) M_RC(1,2) M_RC(1,3) M_RC(1,4) M_RC(1,5) M_RC(1,6) M_RC(1,7)
            M_RC(1,8) M_RC(1,9) M_RC(1,10) M_RC(1,11) M_RC(1,12) M_RC(1,13) M_RC(1,14) M_RC(1,15)
            M_RC(2,0) M_RC(2,1) M_RC(2,2) M_RC(2,3) M_RC(2,4) M_RC(2,5)
            M_RC(2,6) M_RC(2,7) M_RC(2,8) M_RC(2,9) M_RC(2,10) M_RC(2,11)

            /* Right Half (offset by 3 rows) */
            M_RC(3,0) M_RC(3,1) M_RC(3,2) M_RC(3,3) M_RC(3,4) M_RC(3,5) M_RC(3,6) M_RC(3,7)
            M_RC(3,8) M_RC(3,9) M_RC(3,10) M_RC(3,11) M_RC(3,12) M_RC(3,13) M_RC(3,14) M_RC(3,15)
            M_RC(4,0) M_RC(4,1) M_RC(4,2) M_RC(4,3) M_RC(4,4) M_RC(4,5) M_RC(4,6) M_RC(4,7)
            M_RC(4,8) M_RC(4,9) M_RC(4,10) M_RC(4,11) M_RC(4,12) M_RC(4,13) M_RC(4,14) M_RC(4,15)
            M_RC(5,0) M_RC(5,1) M_RC(5,2) M_RC(5,3) M_RC(5,4) M_RC(5,5)
            M_RC(5,6) M_RC(5,7) M_RC(5,8) M_RC(5,9) M_RC(5,10) M_RC(5,11)
        >;
    };
};

&pinctrl {
    spi3_default: spi3_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 17)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 6)>; // D2 on Nice!Nano v2
        };
    };

    spi3_sleep: spi3_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 17)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 6)>;
            low-power-enable;
        };
    };
};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi3_default>;
    pinctrl-1 = <&spi3_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <10>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};

&adc {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;

    /* Standard Nice!Nano A1 → P0.03 → AIN1 */
    channel@1 {
        reg = <1>;
        zephyr,gain = "ADC_GAIN_1_4";
        zephyr,reference = "ADC_REF_VDD_1_4";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,input-positive = <NRF_SAADC_AIN1>;
        zephyr,resolution = <12>;
    };

    /* Standard Nice!Nano A2 → P0.04 → AIN2 */
    channel@2 {
        reg = <2>;
        zephyr,gain = "ADC_GAIN_1_4";
        zephyr,reference = "ADC_REF_VDD_1_4";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,input-positive = <NRF_SAADC_AIN2>;
        zephyr,resolution = <12>;
    };

    /* Standard Nice!Nano A3 → P0.28 → AIN4 */
    channel@4 {
        reg = <4>;
        zephyr,gain = "ADC_GAIN_1_4";
        zephyr,reference = "ADC_REF_VDD_1_4";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,input-positive = <NRF_SAADC_AIN4>;
        zephyr,resolution = <12>;
    };
};
