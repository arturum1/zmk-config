#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>

/ {
    behaviors {
        /* Define a custom actuation: Press at 2.0mm (50%), Release at 1.8mm (45%) */
        he_standard: he_standard {
            compatible = "he,behavior-adjustable-actuation";
            #binding-cells = <0>;
            press-threshold-percent = <50>;
            release-threshold-percent = <45>;
        };
    };

    keymap {
        compatible = "zmk,keymap";
        default_layer {
            // The bindings list must contain exactly one entry per RC entry in the overlay (44 total)
            // Each analog key uses &he_standard &kp <keycode> to apply Hall Effect adjustable actuation
            // Format: &kp stands for "Key Press." Keycodes: https://zmk.dev/docs/keymaps/list-of-keycodes
            // &none can be used for unused key slots
            bindings = <
                /* Row 0 (Mux 0): 16 keys - Number row and modifiers */
                &he_standard &kp ESC   &he_standard &kp N1   &he_standard &kp N2   &he_standard &kp N3
                &he_standard &kp N4   &he_standard &kp N5   &he_standard &kp N6   &he_standard &kp N7
                &he_standard &kp N8   &he_standard &kp N9   &he_standard &kp N0   &he_standard &kp MINUS
                &he_standard &kp EQUAL &he_standard &kp BSLH &he_standard &kp GRAVE &he_standard &kp BSPC

                /* Row 1 (Mux 1): 16 keys - QWERTY row and controls */
                &he_standard &kp TAB  &he_standard &kp Q    &he_standard &kp W    &he_standard &kp E
                &he_standard &kp R    &he_standard &kp T    &he_standard &kp Y    &he_standard &kp U
                &he_standard &kp I    &he_standard &kp O    &he_standard &kp P    &he_standard &kp LBKT
                &he_standard &kp RBKT &he_standard &kp RET  &he_standard &kp DEL  &he_standard &kp PG_UP

                /* Row 2 (Mux 2): 12 keys (channels 0-11 used, 12-15 unused) - Home row and modifiers */
                &he_standard &kp LCTRL &he_standard &kp A   &he_standard &kp S    &he_standard &kp D
                &he_standard &kp F    &he_standard &kp G    &he_standard &kp H    &he_standard &kp J
                &he_standard &kp K    &he_standard &kp L    &he_standard &kp SEMI &he_standard &kp SQT
            >;
            // Total: 16 + 16 + 12 = 44 keys (matches overlay map entries)
        };
    };
};
